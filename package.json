{
    "name": "omnivault",
    "private": true,
    "type": "module",
    "imports": {
        "#/*": "./src/*"
    },
    "scripts": {
        "start": "node ./.output/server/index.mjs",
        "start:dev": "node --env-file=.env ./.output/server/index.mjs",
        "dev": "vite dev --port 3000",
        "build": "vite build",
        "preview": "vite preview",
        "test": "vitest run",
        "format": "biome format",
        "lint": "biome lint",
        "check": "biome check",
        "format:w": "biome format --write",
        "lint:w": "biome lint --write",
        "check:w": "biome check --write",
        "biome:all": "biome format && biome lint && biome check",
        "biome:all:w": "biome format --write && biome lint --write && biome check --write",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "db:push": "drizzle-kit push",
        "db:pull": "drizzle-kit pull",
        "db:studio": "drizzle-kit studio",
        "auth:generate": "auth generate --output ./src/db/auth-schema.ts --config ./src/lib/auth.ts -y"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.1038.0",
        "@better-auth/drizzle-adapter": "^1.6.9",
        "@faker-js/faker": "^10.4.0",
        "@paralleldrive/cuid2": "^3.3.0",
        "@t3-oss/env-core": "^0.13.11",
        "@tailwindcss/vite": "^4.2.4",
        "@tanstack/match-sorter-utils": "latest",
        "@tanstack/query-db-collection": "latest",
        "@tanstack/react-db": "latest",
        "@tanstack/react-devtools": "latest",
        "@tanstack/react-form": "latest",
        "@tanstack/react-query": "latest",
        "@tanstack/react-query-devtools": "latest",
        "@tanstack/react-router": "latest",
        "@tanstack/react-router-devtools": "latest",
        "@tanstack/react-router-ssr-query": "latest",
        "@tanstack/react-start": "latest",
        "@tanstack/react-table": "latest",
        "@tanstack/router-plugin": "^1.167.25",
        "better-auth": "^1.6.9",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "drizzle-kit": "^0.31.10",
        "drizzle-orm": "^0.45.2",
        "framer-motion": "^12.38.0",
        "lucide-react": "^1.11.0",
        "nitro": "3.0.260415-beta",
        "pg": "^8.20.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "react-icons": "^5.6.0",
        "tailwind-merge": "^3.5.0",
        "tailwindcss": "^4.2.4",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.13",
        "@tailwindcss/typography": "^0.5.19",
        "@tanstack/devtools-vite": "latest",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.6.0",
        "@types/pg": "^8.20.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "auth": "^1.6.9",
        "dotenv": "^17.4.2",
        "jsdom": "^29.0.2",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "vite": "^8.0.10",
        "vitest": "^4.1.5"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild",
            "lightningcss"
        ]
    }
}
